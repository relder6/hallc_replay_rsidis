# Standard blocks, pretty small
block T.helicity.*
block CTime*
block *EDTM*

# Coincidence time stuff
variable T.coin.hRF_tdcTime
variable T.coin.pRF_tdcTime

# Reference times
variable T.coin.pFADC_TREF_ROC2_adcPulseTimeRaw
variable T.coin.pT1_tdcTimeRaw
variable T.coin.pT2_tdcTimeRaw
block T.coin.pDCREF*tdcTimeRaw
variable T.coin.hFADC_TREF_ROC1_adcPulseTimeRaw
variable T.coin.hT1_tdcTimeRaw
variable T.coin.hT2_tdcTimeRaw
block T.coin.hDCREF*tdcTimeRaw

# ******************************
# *------------HMS-------------*
# ******************************
# Small blocks
block H.cer.*
block H.gtr.*
block H.kin.*
block H.react.*
block H.rb.*

# Commented out prior to light.def
# block H.tr.*
# block H.bcm.*

# ------------------------------
# hhodo light
block H.hod.Time*
block H.hod.bet*
block H.hod.good*
block H.hod.starttime
variable H.hod.adctdc_offset
variable H.hod.fpHitsTime

# ------------------------------
# hdc light
block H.dc.*best
block H.dc.res*
block H.dc.x*
block H.dc.y*
block H.dc.*.wirenum
block H.dc.*.time
block H.dc.*.dist
variable H.dc.InsideDipoleExit
variable H.dc.chisq

# ------------------------------
# hcal light
variable H.cal.etottracknorm
variable H.cal.nclust
variable H.cal.etotnorm
variable H.cal.eprtracknorm
block H.cal.*good*AdcPulseInt

# ******************************
# *-----------SHMS-------------*
# ******************************
# Small blocks
block P.ngcer.*
block P.hgcer.*
block P.aero.*
block P.gtr.*
block P.kin.*
block P.react.*
block P.rb.*

# Commented out prior to light.def
# block P.tr.*
# block P.hod.*

# ------------------------------
# phodo light
block P.hod.Time*
variable P.hod.adctdc_offset
block P.hod.bet*
variable P.hod.fpHitsTime
block P.hod.good*
block P.hod.starttime

# ------------------------------
# pdc light
block P.dc.*best
block P.dc.res*
block P.dc.x*
block P.dc.y*
block P.dc.*.wirenum
block P.dc.*.time
block P.dc.*.dist
variable P.dc.InsideDipoleExit
variable P.dc.chisq

# ------------------------------
# pcal light
variable P.cal.etottracknorm
block P.cal.n*
block P.cal.fly.n*
block P.cal.*good*AdcPulseInt
variable P.cal.etotnorm
varibale P.cal.eprtracknorm

# ******************************
# *-----------EPICS------------*
# ******************************
begin epics
IBC3H00CRCUR4
hac_bcm_average
ibcm1
ibcm2
iunser
itov3out
itov4out
IPM3H07A.XPOS
IPM3H07A.YPOS
IPM3H07B.XPOS
IPM3H07B.YPOS
IPM3H07C.XPOS
IPM3H07C.YPOS
IPM3H07A.XRAW
IPM3H07A.YRAW
IPM3H07B.XRAW
IPM3H07B.YRAW
IPM3H07C.XRAW
IPM3H07C.YRAW
IPM3H07A.XSOF
IPM3H07A.YSOF
IPM3H07B.XSOF
IPM3H07B.YSOF
IPM3H07C.XSOF
IPM3H07C.YSOF

#Spectrometer Settings (HMS)
ecHMS_Angle
ecP_HMS
#Magnet Currents
ecQ1_Set_Current
ecQ2_I_True
ecQ2_Set_Current
ecQ2_I_True
ecQ3_Set_Current
ecQ3_I_True
ecDI_B_Set_NMR
ecDI_B_True_NMR

#Spectrometer Settings (SHMS)
ecSHMS_Angle
ecSP_SHMS

#Magnet Currents
ecSHB_Set_Current
ecSHB_I_True
ecSQ1_Set_Current
ecSQ1_I_True
ecSQ2_Set_Current
ecSQ2_I_True
ecSQ3_Set_Current
ecSQ3_I_True
ecSDI_B_Set_NMR
ecSDI_B_True_NMR
end epics

